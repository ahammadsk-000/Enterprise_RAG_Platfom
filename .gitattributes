# Normalize line endings to LF in the repo; check out native on Windows.
* text=auto eol=lf

# Windows batch files must keep CRLF (cmd.exe goto/labels are sensitive to it).
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat these as binary (no eol conversion).
*.png binary
*.jpg binary
*.pdf binary
*.ico binary
