# ── Application ──────────────────────────────────────────────────────────────
PROJECT_NAME="Enterprise RAG Platform"
ENVIRONMENT=local              # local | test | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173"]

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=enterprise_rag
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_ECHO=false

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Qdrant (vector DB) ───────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=rag

# ── Neo4j (Graph RAG) ────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# ── Auth / SSO ───────────────────────────────────────────────────────────────
AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=30
AUTH_REFRESH_TOKEN_TTL_DAYS=14
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=

# ── LLM / Embeddings (default: Ollama) ───────────────────────────────────────
LLM_PROVIDER=ollama            # ollama | vllm | openai
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_CHAT_MODEL=llama3.1:8b
LLM_EMBEDDING_PROVIDER=ollama  # ollama | sentence_transformers | openai
LLM_EMBEDDING_MODEL=nomic-embed-text
LLM_EMBEDDING_DIM=768
LLM_REQUEST_TIMEOUT_S=60

# ── Object storage (S3 / MinIO) ──────────────────────────────────────────────
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=rag-documents
STORAGE_REGION=us-east-1
STORAGE_SECURE=false

# ── Observability ────────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=enterprise-rag-api
OTEL_LANGFUSE_PUBLIC_KEY=
OTEL_LANGFUSE_SECRET_KEY=
OTEL_LANGFUSE_HOST=http://localhost:3001
