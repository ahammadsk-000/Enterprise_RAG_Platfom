# ── Frontend env (Vite) ───────────────────────────────────────────────────────
# Backend target for the dev-server proxy (/api -> this URL). Used only in `npm run dev`.
VITE_API_PROXY=http://localhost:8000

# Absolute backend origin for production (Vercel deploy). Leave blank in dev.
# Example: https://enterprise-rag-backend.onrender.com
# Set this in the Vercel dashboard (Project → Settings → Environment Variables).
VITE_API_BASE=
